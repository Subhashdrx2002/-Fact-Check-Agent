"""
make_sample_trap_pdf.py
Generates a small "trap document" PDF with a mix of true, outdated, and
fabricated claims so you can sanity-check the Fact-Check Agent before
submitting. Run once locally: `python make_sample_trap_pdf.py`
"""

from reportlab.lib.pagesizes import letter
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
from reportlab.lib.styles import getSampleStyleSheet

doc = SimpleDocTemplate("sample_trap_document.pdf", pagesize=letter)
styles = getSampleStyleSheet()
story = []

story.append(Paragraph("NimbusAI — Company Overview (Marketing One-Pager)", styles["Title"]))
story.append(Spacer(1, 16))

paragraphs = [
    "NimbusAI is the leading platform for enterprise AI adoption, trusted by "
    "teams worldwide to ship faster and smarter.",

    # Fabricated / false
    "The Eiffel Tower stands 500 meters tall, making it one of the tallest "
    "structures ever built when completed.",

    # Outdated (true once, no longer current)
    "As of our last report, ChatGPT had reached 100 million weekly active "
    "users, a milestone hit in early 2023.",

    # Fabricated
    "Python was created in 1995 by Guido van Rossum as a successor to the "
    "ABC programming language.",

    # True, checkable
    "OpenAI released GPT-4 in March 2023, expanding on the capabilities of "
    "its predecessor models.",

    # Fabricated financial figure
    "The global AI market was valued at $4.8 trillion in 2023, according to "
    "industry estimates.",

    # True
    "Anthropic, the company behind the Claude family of models, was founded "
    "in 2021.",

    # Outdated technical figure
    "Apple became the first publicly traded U.S. company to reach a $500 "
    "billion market capitalization in 2018.",

    # Fabricated
    "The first iPhone was released in 2009 and sold over 50 million units "
    "in its first weekend.",

    "These figures demonstrate the breakneck pace of change across the "
    "technology landscape, and why staying current matters more than ever.",
]

for p in paragraphs:
    story.append(Paragraph(p, styles["Normal"]))
    story.append(Spacer(1, 10))

doc.build(story)
print("Wrote sample_trap_document.pdf")
